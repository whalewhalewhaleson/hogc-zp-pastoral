# Telegram
BOT_TOKEN=
ADMIN_TG_ID=          # Wilson's Telegram user ID — bot DMs you when someone new runs /start

# Google Sheets
SHEET_ID=

# Google service account credentials (use ONE of the following):

# Option A — Preferred for Railway. Two separate vars, no JSON escaping headaches.
# Paste the private_key with its literal \n newlines (Railway auto-expands them).
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Option B — Single JSON blob (works locally; Railway sometimes mangles newlines).
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Option C — Local file (dev only; never commit the file).
# GOOGLE_CREDENTIALS_PATH=./credentials.json
